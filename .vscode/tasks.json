{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cli: build",
      "type": "shell",
      "command": "pnpm -C packages/cli run build",
      "group": "build",
      "problemMatcher": "$tsc"
    },
    {
      "label": "cli: test",
      "type": "shell",
      "command": "pnpm -C packages/cli run test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "cli: lint",
      "type": "shell",
      "command": "pnpm -C packages/cli run lint",
      "group": "test",
      "problemMatcher": [
        "$eslint-stylish"
      ]
    },
    {
      "label": "cli: build exe (pkg)",
      "type": "shell",
      "command": "pnpm -C packages/cli run build:exe",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "mz80: assemble current file",
      "type": "shell",
      "command": "node packages/cli/dist/index.js as \"${file}\" \"${fileDirname}/${fileBasenameNoExtension}.rel\"",
      "dependsOn": [
        "cli: build"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "mz80: link current rel",
      "type": "shell",
      "command": "node packages/cli/dist/index.js link \"${fileDirname}/${fileBasenameNoExtension}.bin\" \"${file}\"",
      "dependsOn": [
        "cli: build"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": []
    }
  ]
}
