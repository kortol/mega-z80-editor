{
  "name": "z80-assembler-language",
  "displayName": "Z80 Assembler Language",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "publisher": "mz80",
  "description": "Z80 assembler language support with syntax highlighting, diagnostics, semantic tokens, and integrated debugging.",
  "icon": "media/icon.png",
  "categories": [
    "Programming Languages",
    "Debuggers"
  ],
  "keywords": [
    "z80",
    "assembler",
    "assembly",
    "debugger",
    "language-server"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kortol/mega-z80-editor.git",
    "directory": "editor/vscode-ext"
  },
  "bugs": {
    "url": "https://github.com/kortol/mega-z80-editor/issues"
  },
  "homepage": "https://github.com/kortol/mega-z80-editor",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:z80-asm",
    "onCommand:mz80.runMake",
    "onDebugInitialConfigurations",
    "onDebugResolve:mz80-dap"
  ],
  "contributes": {
    "languages": [
      {
        "id": "z80-asm",
        "aliases": ["Z80 Assembly", "z80-asm", "asm"],
        "extensions": [".asm"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "z80-asm",
        "scopeName": "source.z80-asm",
        "path": "./syntaxes/z80-asm.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "z80-asm"
      },
      {
        "language": "asm"
      },
      {
        "language": "z80"
      },
      {
        "language": "z80asm"
      },
      {
        "language": "plaintext"
      }
    ],
    "commands": [
      {
        "command": "mz80.runMake",
        "title": "mz80: Run Make"
      }
    ],
    "debuggers": [
      {
        "type": "mz80-dap",
        "label": "MZ80 Debugger",
        "languages": ["z80-asm", "asm", "plaintext", "z80", "z80asm"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to target binary (.com/.bin)"
              },
              "smap": {
                "type": "string",
                "description": "Source map path (.smap). If omitted, <program basename>.smap is auto-detected."
              },
              "sym": {
                "type": "string",
                "description": "Symbol path (.sym). If omitted, <program basename>.sym is auto-detected."
              },
              "base": {
                "type": "string",
                "description": "Optional image base address for dbg (e.g. 0100H)."
              },
              "cpm": {
                "type": "boolean",
                "description": "Run the target with CP/M BDOS support enabled."
              },
              "cpmInteractive": {
                "type": "boolean",
                "description": "Enable interactive console input for CP/M/BIOS console calls."
              },
              "connect": {
                "type": "string",
                "description": "Attach target endpoint (optional in launch)"
              },
              "rpcListen": {
                "type": "string",
                "default": "127.0.0.1:4700",
                "description": "Listen endpoint for auto-started debugger backend in launch"
              },
              "cliEntry": {
                "type": "string",
                "description": "Path to mz80 CLI dist/index.js"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debug adapter process"
              }
            }
          },
          "attach": {
            "required": ["connect"],
            "properties": {
              "connect": {
                "type": "string",
                "default": "127.0.0.1:4700",
                "description": "RPC endpoint (host:port)"
              },
              "cliEntry": {
                "type": "string",
                "description": "Path to mz80 CLI dist/index.js"
              },
              "cwd": {
                "type": "string",
                "description": "Working directory for the debug adapter process"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "MZ80 Launch (BBC BASIC)",
            "type": "mz80-dap",
            "request": "launch",
            "program": "${workspaceFolder}/../mega-z80-examples/bbcbasic-z80/bbcbasic-as.com",
            "cpm": true,
            "cpmInteractive": true,
            "rpcListen": "127.0.0.1:4700"
          },
          {
            "name": "MZ80 Attach (RPC 4700)",
            "type": "mz80-dap",
            "request": "attach",
            "connect": "127.0.0.1:4700"
          }
        ]
      }
    ],
    "configuration": {
      "title": "MZ80",
      "properties": {
        "mz80.debug.cliEntry": {
          "type": "string",
          "default": "",
          "description": "Path to mz80 CLI entry script (dist/index.js). Empty = auto-detect from workspace."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build:full",
    "build:grammar": "node tools/generate-textmate-grammar.js",
    "build:runtimes": "node tools/copy-runtime.js",
    "build:full": "pnpm -C ../../packages/cli run build && pnpm -C ../lsp run build && pnpm run build",
    "build": "pnpm run build:grammar && pnpm run build:runtimes && tsc -p tsconfig.json",
    "package:vsix": "vsce package --no-dependencies --skip-license"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.9.2",
    "@types/node": "^20.14.11",
    "@types/vscode": "^1.90.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pino": "^10.1.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "yaml": "^2.6.0"
  }
}
