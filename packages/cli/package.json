{
  "name": "@mz80/cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "mz80": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js --help",
    "test": "set USERPROFILE=%CD%&& set HOMEPATH=%CD%&& set HOME=%CD%&& jest --runInBand",
    "import:z80test": "ts-node tools/import-z80test.ts",
    "gen:mnemonics": "ts-node tools/gen-peggy-mnemonics.ts",
    "build:parser": "npx peggy -o src/assembler/parser/gen/z80_assembler.js src/assembler/grammar/z80_assembler.pegjs",
    "build:grammar": "npm run gen:mnemonics && npm run build:parser"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "pino": "^10.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/pino": "^7.0.5",
    "jest": "^30.1.3",
    "peggy": "^5.0.6",
    "pino-pretty": "^13.1.2",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
