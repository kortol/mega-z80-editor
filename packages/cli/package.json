{
  "name": "@mz80/cli",
  "version": "0.0.0",
  "private": false,
  "license": "MIT",
  "description": "CLI for the Mega Z80 assembler, linker, debugger, and DAP bridge.",
  "keywords": [
    "z80",
    "assembler",
    "linker",
    "debugger",
    "dap"
  ],
  "homepage": "https://github.com/kortol/mega-z80-editor",
  "bugs": {
    "url": "https://github.com/kortol/mega-z80-editor/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kortol/mega-z80-editor.git",
    "directory": "packages/cli"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "mz80": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm run clean:dist && pnpm run build:parser && pnpm exec tsc -p tsconfig.build.json && node tools/copy-parser.js",
    "clean:dist": "node tools/clean-dist.js",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js --help",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "test": "set USERPROFILE=%CD%&& set HOMEPATH=%CD%&& set HOME=%CD%&& jest --runInBand",
    "gen:mnemonics": "ts-node tools/gen-peggy-mnemonics.ts",
    "build:parser": "pnpm exec peggy -o src/assembler/parser/gen/z80_assembler.js src/assembler/grammar/z80_assembler.pegjs",
    "build:exe": "pnpm run build && pkg dist/index.js --targets node18-win-x64 --output dist-exe/mz80.exe"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pino": "^10.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/pino": "^7.0.5",
    "eslint": "^9.37.0",
    "jest": "^30.1.3",
    "peggy": "^5.0.6",
    "pino-pretty": "^13.1.2",
    "pkg": "^5.8.1",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "pkg": {
    "assets": [
      "dist/assembler/parser/gen/z80_assembler.js"
    ]
  }
}
